# Hotel Schema Maker — Environment Variables
# Copy this file to .env and fill in your values

# ─── Core ──────────────────────────────────────────────
FLASK_ENV=development       # Set to 'production' on deploy
SECRET_KEY=change-me-to-a-random-64-char-string
JWT_SECRET=change-me-to-another-random-64-char-string
PORT=5000

# ─── Database ──────────────────────────────────────────
# SQLite (default — no setup needed for local dev)
SQLITE_PATH=hotel_schema.db

# Supabase (optional — for multi-user production)
# Create a free project at https://supabase.com
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_KEY=your-anon-key-here

# ─── Optional ──────────────────────────────────────────
# Crawler settings
MAX_CRAWL_PAGES=50
CRAWL_DELAY=0.5             # Seconds between requests
